pipeline {
    agent any

    triggers {
        githubPush()
    }

    tools {
        maven 'Maven3'
        jdk 'JDK17'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                echo 'Code récupéré depuis GitHub'
            }
        }

        stage('Build & test') {
            steps {
                dir('backend') {
                    sh '''
                        echo "=== Build + tests + couverture JaCoCo ==="
                        mvn clean verify
                    '''
                }
            }
        }

        stage('Verify JaCoCo Report') {
            steps {
                  dir('backend') {
                    sh '''
                        ls -la target/site/jacoco/ || echo "Dossier jacoco introuvable"
                        test -f target/site/jacoco/jacoco.xml
                    '''
                }
            }

        stage('Package') {
            steps {
                steps {
                    dir('backend') {
                        sh 'mvn package -DskipTests'
                    }
                archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
            }
        }
    }

    post {
        always {
            junit testResults: 'backend/target/surefire-reports/*.xml', allowEmptyResults: true
            echo "Build ${currentBuild.result} - ${env.JOB_NAME} #${env.BUILD_NUMBER}"
            cleanWs()
        }
        success {
            echo 'Pipeline exécuté avec succès !'
        }
        failure {
            echo 'La pipeline a échoué !'
        }
    }
}